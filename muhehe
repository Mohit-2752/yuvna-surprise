<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Valentine Surprise Page</title>
  <style>
    * {
      box-sizing: border-box;
      font-family: 'Poppins', sans-serif;
    }

    body {
      margin: 0;
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      background: url('https://i.pinimg.com/originals/95/b8/8c/95b88c4bd4c32e1dbbae8e30796ba695.jpg') center/cover no-repeat fixed;
      overflow: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background: rgba(255, 255, 255, 0.55);
      backdrop-filter: blur(6px);
      z-index: -1;
    }

    .container {
      perspective: 1000px;
      position: relative;
      width: 320px;
      height: 420px;
    }

    /* Envelope */
    .envelope {
      position: absolute;
      width: 100%;
      height: 220px;
      bottom: 0;
      background: #ffc0cb;
      border-radius: 0 0 16px 16px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.25);
      cursor: pointer;
      z-index: 5;
      overflow: hidden;
      transition: transform 0.6s ease, opacity 0.6s ease;
    }

    .envelope::before,
    .envelope::after {
      content: "";
      position: absolute;
      bottom: 0;
      width: 0;
      height: 0;
      border-style: solid;
    }

    .envelope::before {
      left: 0;
      border-width: 110px 0 0 160px;
      border-color: transparent transparent transparent #ffb6c1;
    }

    .envelope::after {
      right: 0;
      border-width: 110px 160px 0 0;
      border-color: transparent #ffb6c1 transparent transparent;
    }

    .flap {
      position: absolute;
      top: 0;
      left: 0;
      width: 0;
      height: 0;
      border-left: 160px solid transparent;
      border-right: 160px solid transparent;
      border-top: 120px solid #ff9eb5;
      transform-origin: top;
      transition: transform 0.6s ease;
      pointer-events: none; /* allow click to reach envelope */
    }

    .envelope.open .flap {
      transform: rotateX(180deg);
    }

    .envelope.hide .flap {
      transform: rotateX(180deg);
    }

    .envelope.hide {
      transform: translateY(200px);
      opacity: 0;
      pointer-events: none;
    }

    /* Card */
    .card {
      position: absolute;
      top: 60px;
      left: 50%;
      transform: translateX(-50%) translateY(40px);
      width: 90%;
      background: white;
      border-radius: 20px;
      padding: 25px;
      text-align: center;
      box-shadow: 0 15px 35px rgba(0,0,0,0.2);
      opacity: 0;
      transition: transform 0.8s ease, opacity 0.8s ease;
      z-index: 1;
    }

    .card.show {
      transform: translateX(-50%) translateY(-40px);
      opacity: 1;
      z-index: 10;
    }

    h2 {
      color: #ff4d6d;
      margin-bottom: 15px;
    }

    p {
      font-size: 14px;
      line-height: 1.6;
      color: #444;
    }

    .question {
      margin-top: 20px;
      font-weight: bold;
    }

    .yes {
      margin-top: 20px;
      padding: 12px 28px;
      border: none;
      border-radius: 999px;
      background: #ff4d6d;
      color: white;
      font-size: 16px;
      cursor: pointer;
      box-shadow: 0 8px 20px rgba(255,77,109,0.4);
      transition: transform 0.2s ease;
    }

    .yes:hover {
      transform: scale(1.08);
    }

    .no {
      margin-top: 12px;
      padding: 10px 22px;
      border: none;
      border-radius: 999px;
      background: #ccc;
      color: #333;
      font-size: 14px;
      cursor: pointer;
      position: absolute;
      left: 50%;
      top: 300px; /* move NO further away from YES */
      transform: translateX(-50%);
    }

  .popup {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%) scale(0.8);
      background: white;
      padding: 40px 45px;
      border-radius: 24px;
      box-shadow: 0 20px 40px rgba(0,0,0,0.3);
      text-align: center;
      opacity: 0;
      pointer-events: none;
      transition: all 0.5s ease;
      z-index: 20;
      width: 420px;
      max-width: 90vw;
    }

    .popup.show {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1);
      pointer-events: auto;
    }

    </style>
</head>
<body>

  <div class="container">
    
    <div class="card" id="card">
      <h2>Hey Yuvna 🥺</h2>
      <p>
        I know I might have messed up and I’ve been thinking about it a lot.
        The last thing I ever want is to hurt you or make you feel bad.
        You mean a lot to me and it genuinely bothers me knowing I upset you.
      </p>
      <p class="question">Will you forgive me? 💌</p>
      <button class="yes">Forgive Me ❤️</button>
      <button class="no" id="noBtn">No 😏</button>
    </div>

    <div class="popup" id="popup">
      <h2>Thank you for forgiving me 🥹❤️</h2>
      <p>
        That honestly means more to me than you know.<br><br>
        I never want to be the reason you’re upset,
        and I promise I’ll try to be better, more careful, and more understanding.<br><br>
        You’re really important to me and I don’t want silly mistakes
        to ever come between us again.<br><br>
        Thank you for giving me another chance 💕
      </p>
      </p>
    </div>

    <div class="envelope" id="envelope">
      <div class="flap"></div>
    </div>
  </div>

  <script>
    const envelope = document.getElementById('envelope');
    const card = document.getElementById('card');

    envelope.addEventListener('click', () => {
      envelope.classList.add('open');

      // let the flap open first, then hide envelope
      setTimeout(() => {
        envelope.classList.add('hide');
        card.classList.add('show');
      }, 600);
    });

    const noBtn = document.getElementById('noBtn');
    const yesBtn = document.querySelector('.yes');
    const popup = document.getElementById('popup');

    noBtn.addEventListener('mouseover', () => {
      const x = Math.random() * 200 - 100;
      const y = Math.random() * 120 - 60;
      noBtn.style.transform = `translate(${x}px, ${y}px)`;
    });

    yesBtn.addEventListener('click', () => {
      // hide the card first
      card.classList.remove('show');

      // show popup after card fades
      setTimeout(() => {
        popup.classList.add('show');
      }, 500);
    });
  </script>

</body>
</html>
